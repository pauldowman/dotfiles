{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(*)",
      "Read",
      "Edit",
      "Write",
      "NotebookEdit",
      "Mcp:*",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(git checkout *)",
      "Bash(git switch *)"
    ]
  },
  "hooks": {}
}
