#!/bin/bash

# Refuse to push commits that aren't signed.
# %G? letters: G/U/X/Y/R/E mean signed (E = signed but not verifiable here);
# N = no signature, B = bad signature.

exec 1>&2

unsigned=()
while read -r local_ref local_sha remote_ref remote_sha; do
  [[ "$local_sha" =~ ^0+$ ]] && continue  # branch deletion, nothing to check

  if [[ "$remote_sha" =~ ^0+$ ]]; then
    commits=$(git log --format='%H %G?' "$local_sha" --not --remotes)
  else
    commits=$(git log --format='%H %G?' "${remote_sha}..${local_sha}")
  fi

  while read -r sha sigstatus; do
    [[ -z "$sha" ]] && continue
    if [[ "$sigstatus" == "N" || "$sigstatus" == "B" ]]; then
      unsigned+=("$sha")
    fi
  done <<< "$commits"
done

if (( ${#unsigned[@]} > 0 )); then
  echo "pre-push: refusing to push ${#unsigned[@]} unsigned commit(s):"
  for sha in "${unsigned[@]}"; do
    git log -1 --format='  %h %s' "$sha"
  done
  echo
  echo "Sign them, e.g.:  git sign-since <base>"
  exit 1
fi
